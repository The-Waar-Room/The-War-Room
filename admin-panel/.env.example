NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BACKEND_BASE_URL=http://localhost:8080

# Firebase Admin credentials for Firestore and Google API access.
# If you use Application Default Credentials instead, you can leave these blank.
FIREBASE_PROJECT_ID=the-war-room-sudo
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"

# Optional override for ADC JSON credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional explicit GA4 property IDs.
# Leave blank if the admin panel service account can auto-discover the linked
# Android app stream through the Analytics Admin API.
GA4_PROPERTY_ID_DESCROLL=
GA4_PROPERTY_ID_SOULLENS=
GOOGLE_ANALYTICS_PROPERTY_ID_DESCROLL=
GOOGLE_ANALYTICS_PROPERTY_ID_SOULLENS=

# Crashlytics BigQuery export settings.
# Data project defaults to FIREBASE_PROJECT_ID.
CRASHLYTICS_BIGQUERY_PROJECT_ID=the-war-room-sudo
# Query project can be different from the Firebase project if this service
# account can create BigQuery jobs there.
CRASHLYTICS_BIGQUERY_QUERY_PROJECT_ID=
BIGQUERY_QUERY_PROJECT_ID=
CRASHLYTICS_BIGQUERY_DATASET=firebase_crashlytics
CRASHLYTICS_SESSIONS_BIGQUERY_DATASET=firebase_sessions
